# Backend API base URL (e.g. https://memoria-backend.onrender.com/api)
# Leave unset locally to default to http://localhost:3000/api
REACT_APP_API_URL=

# Backend Socket.IO URL (e.g. https://memoria-backend.onrender.com)
# Leave unset locally to default to http://localhost:3000
REACT_APP_SOCKET_URL=
