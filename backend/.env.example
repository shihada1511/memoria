# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Deployed frontend origin (e.g. https://memoria-frontend.onrender.com).
# Leave unset locally to allow all origins.
FRONTEND_URL=

# ─── MySQL Database ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=memoria_db
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── AI Integration (Groq) ────────────────────────────────────────────────────
# Set this to your Groq API key (free tier, no billing required).
# Get one at https://console.groq.com/keys
# NEVER commit the real key — this file is safe to commit.
AI_API_KEY=gsk_...
