# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MySQL Database ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=memoria_db
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here

